# Copy to .env for docker compose or local development (do not commit .env)
# NCBI (PubMed collect)
# NCBI_API_KEY=
# NCBI_EMAIL=

# LLM / insights (set at least one provider you use)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=

# Optional compose port
# MED_ASSERT_PORT=8000
